<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FkmainActivity">

    <!-- 헤더 -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#4CAF50"
            android:textSize="24sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- 검색 바 -->
    <EditText
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/header"
        android:layout_margin="16dp"
        android:hint="@string/search_hint"
        android:background="@drawable/fk_search"
        android:padding="8dp"/>

    <!-- 탭 -->
    <LinearLayout
        android:id="@+id/tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/search_bar"
        android:orientation="horizontal">

        <Button
            android:id="@+id/tab_all"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/tab_all"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#4CAF50"/>

        <Button
            android:id="@+id/tab_frozen"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/tab_frozen"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/tab_refrigerated"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/tab_refrigerated"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#4CAF50"/>

        <Button
            android:id="@+id/tab_room_temp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/tab_room_temp"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#4CAF50"/>
    </LinearLayout>

    <!-- 아이템 리스트 -->
    <ScrollView
        android:id="@+id/itemList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/tabs"
        android:layout_above="@id/footer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 반복되는 아이템 블록 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/item_image"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/fk_bibigo"
                    android:contentDescription="@string/item_image_desc"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/item_image"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/item_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_name"
                        android:textSize="18sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:id="@+id/item_reg_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_reg_date"
                        android:textSize="14sp"
                        android:textColor="#757575"/>

                    <TextView
                        android:id="@+id/item_exp_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_exp_date"
                        android:textSize="14sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/item_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="@string/item_countdown"
                    android:textSize="24sp"
                    android:textColor="#FF0000"/>
            </RelativeLayout>
            <!-- 아이템 블록 반복 -->

        </LinearLayout>
    </ScrollView>

    <!-- 푸터 -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#8BC34A"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/icon_ref"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/fk_ref"
            android:tint="#FFFFFF"
            android:contentDescription="@string/icon_ref_desc"/>

        <ImageView
            android:id="@+id/icon_calendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/fk_calendar"
            android:tint="#FFFFFF"
            android:contentDescription="@string/icon_calendar_desc"/>

        <ImageView
            android:id="@+id/icon_barcode"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/fk_bar"
            android:tint="#FFFFFF"
            android:contentDescription="@string/icon_barcode_desc"/>

        <ImageView
            android:id="@+id/icon_mypage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/fk_mypage"
            android:tint="#FFFFFF"
            android:contentDescription="@string/icon_mypage_desc"/>
    </LinearLayout>

    <!-- 플로팅 액션 버튼 -->
    <ImageButton
        android:id="@+id/fab"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:layout_alignParentEnd="true"
        android:backgroundTint="#4CAF50"
        android:src="@drawable/fk_logo"
        android:tint="#FFFFFF"
        android:contentDescription="@string/fab_desc"/>
</RelativeLayout>